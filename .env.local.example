# ============================================================================
# NOMOS GT — Variáveis de ambiente
# ============================================================================
# Copie esse arquivo para .env.local e preencha as chaves.
# .env.local NÃO entra no git (já está no .gitignore por padrão do Next.js).
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE (OBRIGATÓRIO para form de contato, simulador e admin)
# ----------------------------------------------------------------------------
# Pegue em: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# SITE URL (recomendado — usado em emails e canonical)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://nomos.gt

# ----------------------------------------------------------------------------
# IP HASH SALT (recomendado — privacidade dos visitantes)
# ----------------------------------------------------------------------------
# Qualquer string aleatória longa. Usado pra hashear IPs antes de armazenar.
# Gere com: `openssl rand -hex 32`
IP_HASH_SALT=troque-isso-por-uma-string-aleatoria-longa

# ----------------------------------------------------------------------------
# RESEND — Email de notificação (OPCIONAL mas recomendado)
# ----------------------------------------------------------------------------
# Pegue em: https://resend.com → API Keys
# Plano grátis: 100 emails/dia, 3000/mês.
# Sem essa chave, novos contatos NÃO disparam e-mail (mas continuam salvos no DB).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=NOMOS GT <contato@nomos.gt>
EMAIL_NOTIF_TO=everton@nomos.gt

# ----------------------------------------------------------------------------
# ANTHROPIC — Análise IA do CNPJ (OPCIONAL)
# ----------------------------------------------------------------------------
# Sem essa chave, /cnpj continua funcionando mas só mostra dados públicos
# (BrasilAPI + ReceitaWS) — sem a parte de análise tributária gerada por IA.
# Pegue em: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------------------------
# UPSTASH REDIS — Rate limit (OPCIONAL)
# ----------------------------------------------------------------------------
# Pegue em: https://console.upstash.com → Create Database (Redis, Global)
# Plano grátis: 10k requests/dia.
# Sem isso, o rate-limit vira no-op (sempre permite). Forms ficam vulneráveis a spam.
UPSTASH_REDIS_REST_URL=https://xxxx-xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
